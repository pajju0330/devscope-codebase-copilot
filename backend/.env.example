## DevScope (backend) local secrets
# Copy this file to `.env` (gitignored) and fill in your real key.

# Preferred name (matches application.yml)
DEVSCOPE_LLM_API_KEY=
DEVSCOPE_LLM_BASE_URL=

# Model names (optional overrides)
DEVSCOPE_LLM_MODEL=
DEVSCOPE_EMBEDDING_MODEL=

# Database (optional for local; Railway Postgres provides these automatically)
PGHOST=localhost
PGPORT=5432
PGDATABASE=devscope
PGUSER=devscope
PGPASSWORD=devscope

# Port (Railway provides this automatically)
PORT=8080

